{
  "name": "apportionments-sveltekit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:integration && npm run test:unit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:integration": "playwright test",
    "test:integration:ui": "playwright test --ui",
    "test:unit": "vitest",
    "collect": "tsx bin/collect.ts",
    "db:generate-migration": "drizzle-kit generate:pg",
    "db:migrate": "tsx bin/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.537.0",
    "@aws-sdk/credential-providers": "^3.535.0",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "date-fns-tz": "^3.0.1",
    "drizzle-orm": "^0.29.4",
    "fs-extra": "^11.2.0",
    "lodash-es": "^4.17.21",
    "modern-normalize": "^2.0.0",
    "moment": "^2.30.1",
    "multi-progress-bars": "^5.0.3",
    "node-html-parser": "^6.1.12",
    "pg": "^8.11.3",
    "svelte": "^5.0.0-next.106",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "@melt-ui/svelte": "^0.76.3",
    "@playwright/test": "^1.28.1",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-node": "^5.0.1",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/eslint": "^8.56.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.36.0-next.4",
    "prettier": "^3.1.1",
    "prettier-plugin-brace-style": "^0.5.0",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte-check": "^3.6.0",
    "tslib": "^2.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.0.0",
    "vite": "^5.2.8",
    "vitest": "^1.4.0"
  },
  "overrides-comment": [
    "Overrides dependencies of dependencies.  Requires npm 8+",
    "Fixes UI library version restriction for svelte 5 (warnings still present)"
  ],
  "overrides": {
    "@melt-ui/svelte": {
      "svelte": "^5.0.0-next.100"
    }
  }
}
