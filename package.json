{
  "name": "apportionments-sveltekit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "dev": "npm run dev:web",
    "dev:web": "dotenvx run -- vite dev",
    "dev:migrate": "dotenvx run -- tsx bin/migrate.ts",
    "dev:collect": "dotenvx run -- tsx bin/collect.ts",
    "dev:notify": "npm run build:notify && dotenvx run -- node build-notify/notify.js",
    "dev:test-email": "npm run build:test-email && dotenvx run -- node build-test-email/test-email.js",
    "build:web": "vite build",
    "build:collect": "vite build --config vite-bin.config.ts --ssr bin/collect.ts --outDir build-collect",
    "build:migrate": "vite build --config vite-bin.config.ts --ssr bin/migrate.ts --outDir build-migrate",
    "build:notify": "vite build --config vite-bin.config.ts --ssr bin/notify.ts --outDir build-notify",
    "build:test-email": "vite build --config vite-bin.config.ts --ssr bin/test-email.ts --outDir build-test-email",
    "build": "npm run build:web && npm run build:collect && npm run build:migrate && npm run build:notify && npm run build:test-email",
    "preview": "npm run preview:web",
    "preview:web": "dotenvx run -- vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "lint-staged": "lint-staged",
    "format": "prettier --write . && eslint --fix .",
    "test": "npm run test:integration && npm run test:unit",
    "test:integration": "playwright test",
    "test:integration:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "db:generate-migration": "drizzle-kit generate",
    "db:migrate": "tsx bin/migrate.ts",
    "collect": "tsx bin/collect.ts",
    "notify": "npm run build:notify && node build-notify/notify.js",
    "test-email": "npm run build:test-email && node build-test-email/test-email.js",
    "csv-to-ts": "tsx bin/csv-to-ts.ts"
  },
  "lint-staged": {
    "*/**/*.{js,jsx,ts,tsx,svelte}": [
      "prettier --write",
      "eslint --fix",
      "eslint"
    ],
    "*/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@auth/sveltekit": "^1.11.1",
    "@aws-sdk/client-s3": "^3.983.0",
    "@aws-sdk/credential-providers": "^3.983.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@fontsource/domine": "^5.2.8",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@sentry/browser": "^10.38.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@sentry/sveltekit": "^10.38.0",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "chroma-js": "^3.2.0",
    "commander": "^14.0.3",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.37.0",
    "fs-extra": "^11.3.3",
    "lodash-es": "^4.17.23",
    "lru-cache": "^10.2.2",
    "luxon": "^3.7.2",
    "mailgun.js": "^12.7.0",
    "modern-normalize": "^3.0.1",
    "multi-progress-bars": "^5.0.3",
    "node-html-parser": "^6.1.12",
    "pdfjs-dist": "^4.9.155",
    "pg": "^8.18.0",
    "reduce-css-calc": "^2.1.8",
    "svelte": "^5.49.2",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "@melt-ui/svelte": "^0.86.6",
    "@playwright/test": "^1.58.1",
    "@sentry/rollup-plugin": "^4.9.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/eslint": "^9.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "autoprefixer": "^10.4.24",
    "drizzle-kit": "^0.29.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "express": "^4.21.2",
    "husky": "^9.1.7",
    "juice": "^11.1.1",
    "lint-staged": "^16.2.7",
    "nodemailer": "^7.0.11",
    "postcss-custom-media": "^12.0.0",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-brace-style": "^0.9.0",
    "prettier-plugin-svelte": "^3.4.1",
    "schema-dts": "^1.1.5",
    "svelte-check": "^4.3.6",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-imagetools": "^9.0.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides-comment": [
    "Overrides dependencies of dependencies.  Requires npm 8+",
    "Fixes UI library version restriction for svelte 5 (warnings still present)"
  ],
  "overrides": {
    "@melt-ui/svelte": {
      "svelte": "^5.49.2"
    }
  }
}
