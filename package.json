{
  "name": "apportionments-sveltekit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "dev": "dotenvx run -- vite dev",
    "dev:web": "npm run dev",
    "dev:email": "dotenvx run -- tsx email/server.ts",
    "build:web": "vite build",
    "build:collect": "vite build --config vite-bin.config.ts --ssr bin/collect.ts --outDir build-collect",
    "build:migrate": "vite build --config vite-bin.config.ts --ssr bin/migrate.ts --outDir build-migrate",
    "build:notify": "vite build --config vite-bin.config.ts --ssr bin/notify.ts --outDir build-notify",
    "build": "npm run build:web && npm run build:collect && npm run build:migrate && npm run build:notify",
    "preview": "npm run preview:web",
    "preview:web": "dotenvx run -- vite preview",
    "preview:collect": "dotenvx run -- node build-collect/collect.js",
    "preview:migrate": "dotenvx run -- node build-migrate/migrate.js",
    "preview:notify": "dotenvx run -- node build-notify/notify.js",
    "test": "npm run test:integration && npm run test:unit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "lint-staged": "lint-staged",
    "format": "prettier --write . && eslint --fix .",
    "test:integration": "playwright test",
    "test:integration:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "collect": "tsx bin/collect.ts",
    "notify": "tsx bin/notify.ts",
    "email": "tsx bin/email.ts",
    "db:generate-migration": "drizzle-kit generate",
    "db:migrate": "tsx bin/migrate.ts"
  },
  "lint-staged": {
    "*/**/*.{js,jsx,ts,tsx,svelte}": [
      "prettier --write",
      "eslint --fix",
      "eslint"
    ],
    "*/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@auth/drizzle-adapter": "^1.7.4",
    "@auth/sveltekit": "^1.7.4",
    "@aws-sdk/client-s3": "^3.577.0",
    "@aws-sdk/credential-providers": "^3.535.0",
    "@dotenvx/dotenvx": "^0.34.0",
    "@fontsource/domine": "^5.0.19",
    "@fontsource/ibm-plex-sans": "^5.0.20",
    "@sentry/browser": "^8.33.0",
    "@sentry/node": "^8.33.0",
    "@sentry/profiling-node": "^8.33.0",
    "@sentry/sveltekit": "^8.33.0",
    "@sveltelaunch/svelte-5-email": "^0.0.11",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.37.0",
    "fs-extra": "^11.2.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^10.2.2",
    "luxon": "^3.5.0",
    "modern-normalize": "^2.0.0",
    "multi-progress-bars": "^5.0.3",
    "node-html-parser": "^6.1.12",
    "pdfjs-dist": "^4.9.155",
    "pg": "^8.11.3",
    "svelte": "^5.19.10",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "@melt-ui/svelte": "^0.79.1",
    "@playwright/test": "^1.28.1",
    "@sentry/rollup-plugin": "^2.16.1",
    "@sveltejs/adapter-auto": "^3.2.0",
    "@sveltejs/adapter-node": "^5.0.1",
    "@sveltejs/kit": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@types/eslint": "^8.57.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vitejs/plugin-legacy": "^5.3.2",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.29.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "express": "^4.21.2",
    "husky": "^9.0.11",
    "juice": "^11.0.0",
    "lint-staged": "^15.2.2",
    "nodemailer": "^6.10.0",
    "postcss-custom-media": "^10.0.4",
    "postcss-nesting": "^12.1.4",
    "prettier": "^3.1.1",
    "prettier-plugin-brace-style": "^0.5.0",
    "prettier-plugin-svelte": "^3.2.3",
    "schema-dts": "^1.1.2",
    "svelte-check": "^3.7.1",
    "tslib": "^2.4.1",
    "tsx": "^4.10.5",
    "typescript": "^5.0.0",
    "vite": "^5.2.8",
    "vite-imagetools": "^7.0.5",
    "vitest": "^1.4.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides-comment": [
    "Overrides dependencies of dependencies.  Requires npm 8+",
    "Fixes UI library version restriction for svelte 5 (warnings still present)"
  ],
  "overrides": {
    "@melt-ui/svelte": {
      "svelte": "^5.19.10"
    }
  }
}
